<!doctype html>
<html>

<head>
    <meta charset="utf-8">
    <title>新規館員登録 - =LOVE UNOFFICIAL SITE</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <h2>新規会員登録</h2>

    <form action="/register" method="post" class="form-container">
        <div class="form-group">
            <label for="uname">User:</label>
            <input type="text" id="uname" name="uname" required>
        </div>

        <div class="form-group">
            <label for="password">Password:</label>
            <input type="password" id="password" name="password" required>
        </div>

        <button type="submit" class="submit-btn">アカウントを作成する</button>
    </form>
    
    <br>
    <p>すでにアカウントをお持ちの方は<a href='/login'>こちら</a>からログイン</p>
    <a href="/">TOPPAGE</a>
    
    
</body>

</html>